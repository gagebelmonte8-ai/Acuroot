# ---- Shopify storefront ----
# This site checks out via Shopify cart permalinks — no API token needed.
# Just set your store's *.myshopify.com domain (or your primary domain).
# Copy this file to ".env" and restart `npm run dev`.

VITE_SHOPIFY_DOMAIN=your-store.myshopify.com

# Product/variant IDs live in src/lib/shopify.js (VARIANTS + CARE_VARIANT).
# They are public (they appear in cart URLs), so they are safe to commit.
# If you recreate the product in Shopify, update those IDs to match.
